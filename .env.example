# ==================================
# SUSSTYLE UHA - ENVIRONMENT VARIABLES
# ==================================

# OpenAI API Key (WYMAGANE)
# Pobierz z: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Vercel automatycznie ustawia te zmienne - nie musisz ich dodawac:
# - VERCEL_URL (URL deployment)
# - VERCEL_ENV (production/preview/development)

# Opcjonalne: Supabase (dla przyszlej bazy wiedzy)
# NEXT_PUBLIC_SUPABASE_URL=your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key
